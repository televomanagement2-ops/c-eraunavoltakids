# Copia in .env (non committare .env).
# Dashboard Supabase → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Opzionale: URL pubblico “stabile” del sito (consigliato su Vercel per Google OAuth).
# Esempio: https://nome-progetto.vercel.app
# VITE_SITE_URL=https://YOUR_SITE_URL

# Opzionale: "true" usa i prodotti mock quando la tabella products è vuota (dev)
# VITE_USE_CATALOG_MOCK=true
